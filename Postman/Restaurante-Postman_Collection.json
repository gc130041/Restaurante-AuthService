        {
          "name": "Iniciar sesión",
          "event": [
            {
              "listen": "test",
              "script": {
                "id": "41b7e2b1-ad48-4b01-811c-69e7c9c8c335",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "let data = {};",
                  "try { data = pm.response.json(); } catch (e) {}",
                  "const token = data?.token;",
                  "pm.test('Token recibido', function () {",
                  "  pm.expect(token).to.be.a('string').and.not.empty;",
                  "});",
                  "if (token) pm.collectionVariables.set('token', token);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "prerequest",
